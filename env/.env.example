PROJECT_NAME=sosal

APP__HOST=0.0.0.0
APP__PORT=8000
# APP__ENV=production    # дефолт local; APP__DEBUG=true — для локального дева

# Perplexity AI-поиск досье. Внешний ключ — ЗАПОЛНИТЬ ВРУЧНУЮ (пусто = функция off).
PERPLEXITY__API_KEY=

DB__HOST=postgres
DB__PORT=5432
DB__USER=sosal
DB__PASSWORD= ## dotenver:password(name=db_password, length=32, special_chars=False)
DB__NAME=sosal


S3__ENDPOINT_URL=http://minio:9000
S3__ACCESS_KEY=minioadmin
S3__SECRET_KEY= ## dotenver:password(name=s3_secret, length=40, special_chars=False)
S3__BUCKET=sosal

# --- Authentik (SSO / forward-auth) ---
# Секрет authentik — генерируется автоматически (аналог openssl rand -base64 60).
AUTHENTIK_SECRET_KEY= ## dotenver:password(length=60, special_chars=False)
# Публикация логина/админки authentik (дефолт 127.0.0.1:9300). Прод: дефолт верен —
# наружу пускает только Cloudflare Tunnel (см. docs/cloudflare-tunnel.md), 0.0.0.0 не нужен.
# AUTHENTIK_BIND_HOST=127.0.0.1
# AUTHENTIK_HOST_PORT=9300

# Вход приложения (traefik). Локально дефолт 127.0.0.1:8080. Прод: дефолт верен —
# наружу пускает только туннель (traefik:80 внутри docker-сети), 0.0.0.0 не нужен.
# WEB_BIND_HOST=127.0.0.1
# WEB_HOST_PORT=8080

# Домены фронта для CORS бэка (нужно только для dev: хостовой vite ходит на 127.0.0.1:8000
# напрямую). Прод — same-origin через traefik, CORS не требуется.
APP__CORS_ORIGINS=http://localhost:5500,http://localhost:5173
# База API для сборки фронта. Прод — /api/v1 (same-origin через traefik).
# Хостовой dev-vite использует frontend/.env (http://127.0.0.1:8000/api/v1).
VITE_API_URL=/api/v1

# --- Cloudflare Tunnel (прод) ---
# Токен туннеля — ЗАПОЛНИТЬ ВРУЧНУЮ: Zero Trust → Networks → Tunnels → Create.
CLOUDFLARE__TOKEN=

# Домен прод-сервера для Host-роутеров traefik (docker/traefik/dynamic.yml).
# Каждый сервер задаёт свой: deploy-dev.online / sosal.boats / ...
# SHIPVI_DOMAIN=deploy-dev.online

# --- Forward-auth блюпринт authentik (docker/authentik/blueprints/ship-vi.yaml) ---
# Дефолты — локальный контур (single-app на localhost). Прод (домены через туннель):
# SHIPVI_PROXY_MODE=forward_domain
# SHIPVI_EXTERNAL_HOST=https://auth.deploy-dev.online
# SHIPVI_COOKIE_DOMAIN=deploy-dev.online
# SHIPVI_AUTHENTIK_HOST=https://auth.deploy-dev.online
# SHIPVI_AUTHENTIK_HOST_BROWSER=
# SHIPVI_POST_LOGOUT_URL=https://deploy-dev.online/

# --- Google OAuth (кнопка «Войти через Google» в authentik) ---
# Внешние значения — ЗАПОЛНИТЬ ВРУЧНУЮ (пусто = кнопка Google не появляется):
# console.cloud.google.com → APIs & Services → Credentials → OAuth client ID.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Обязательный TOTP / Google Authenticator (блюпринт authentik) ---
# SHIPVI_ENFORCE_TOTP=true
